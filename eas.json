{
  "build": {
    "production": {
      "channel": "production",
      "node": "22.12.0",
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "config": "android-yarn4.yml"
      },
      "ios": {
        "simulator": false,
        "image": "latest",
        "config": "ios-yarn4.yml"
      }
    },
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.12.0",
      "ios": {
        "simulator": true,
        "config": "ios-simulator-yarn4.yml"
      },
      "android": {
        "distribution": "internal",
        "config": "android-yarn4.yml"
      }
    },
    "firebase-testing": {
      "channel": "firebase-testing",
      "node": "22.12.0",
      "android": {
        "distribution": "internal",
        "config": "android-yarn4.yml"
      },
      "ios": {
        "distribution": "internal",
        "config": "ios-yarn4.yml"
      }
    }
  },
  "cli": {
    "appVersionSource": "remote"
  }
}
