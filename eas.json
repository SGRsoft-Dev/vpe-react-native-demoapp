    "firebase-testing": {
      "channel": "firebase-testing",
      "android": {
        "distribution": "internal"
      },
      "ios": {
        "distribution": "internal"
      },
      "node": "22.12.0",
      "preInstall": "corepack enable && corepack prepare yarn@4.9.4 --activate"
    }
