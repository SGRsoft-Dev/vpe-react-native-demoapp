{
  "build": {
    "production": {
      "channel": "production",
      "node": "22.12.0",
      "android": {
        "buildType": "apk",
        "config": "android-yarn4.yml"
      },
      "ios": {
        "config": "ios-yarn4.yml"
      }
    },
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.12.0",
      "ios": {
        "simulator": true,
        "config": "ios-yarn4.yml"
      },
      "android": {
        "distribution": "internal",
        "config": "android-yarn4.yml"
      }
    },
    "firebase-testing": {
      "channel": "firebase-testing",
      "node": "22.12.0",
      "android": {
        "distribution": "internal",
        "config": "android-yarn4.yml"
      },
      "ios": {
        "distribution": "internal",
        "config": "ios-yarn4.yml"
      }
    }
  }
}
