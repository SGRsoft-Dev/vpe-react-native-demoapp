{
  "name": "player-test-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "-----": "",
    "android:prebuild": "expo prebuild --platform android",
    "ios:prebuild": "expo prebuild --platform ios",
    "android:dev": "expo run:android  --no-build-cache ",
    "android:prod": "expo run:android  --configuration production --no-build-cache ",
    "ios:dev": "expo run:ios --configuration Debug --no-build-cache",
    "ios:dev:simulator": "expo run:ios --configuration Debug --no-build-cache --device \"iPhone 17 Pro\"",
    "ios:prod": "expo run:ios --configuration production --no-build-cache",
    "eas:android:prod": "eas build -p android --profile production",
    "eas:android:dev": "eas build -p android --profile development",
    "eas:ios:prod": "eas build -p ios --profile production",
    "eas:ios:dev": "eas build -p ios --profile development",
    "eas:ios:submit": "eas build -p ios --profile production && eas submit -p ios",
    "eas:ios:submitOnly": " eas submit -p ios",
    "eas:android:submit": "eas build -p android --profile production  &&  eas submit -p android --profile firebase-testing",
    "eas:android:only:submit": "eas submit -p android --profile firebase-testing",
    "------": "",
    "sdk:build": "yarn --cwd ../vpe-react-native prepare",
    "sdk:pack": "yarn sdk:build && yarn --cwd ../vpe-react-native pack -o ../vpe-react-native-demoapp/vendor/vpe-react-native.tgz",
    "sdk:vendor": "yarn sdk:pack && yarn add vpe-react-native@file:./vendor/vpe-react-native.tgz",
    "sdk:link": "yarn add vpe-react-native@portal:../vpe-react-native"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.8",
    "@sgrsoft/react-native-video": "^6.16.1-sgrsoft.4",
    "expo": "^54.0.0",
    "expo-application": "~7.0.8",
    "expo-dev-client": "~6.0.21",
    "expo-localization": "~17.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-network": "~8.0.8",
    "expo-screen-capture": "~8.0.9",
    "expo-screen-orientation": "~9.0.9",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "phosphor-react-native": "^3.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-base64": "^0.2.1",
    "react-native-capture-protection": "^2.3.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "vpe-react-native": "file:./vendor/vpe-react-native.tgz"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "baseline-browser-mapping": "^2.10.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "yarn@4.9.4+sha256.516deeeced90791213ddcffc8d6712fcea7adff3e8d9879804284ba713462ce2",
  "resolutions": {
    "expo-constants": "~18.0.13",
    "expo-manifests": "~1.0.11",
    "expo-updates-interface": "~2.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-dev-launcher": "~6.0.21",
    "expo-dev-menu": "~7.0.19",
    "expo-dev-menu-interface": "~2.0.0"
  }
}
